    "js-logger": "1.6.1",
    "js-md5": "0.9.2",
    "json-schema": "0.4.0",
    "keycloak-js": "26.2.4",
    "lodash": "4.18.1",
    "moment": "2.30.1",
    "monaco-editor": "0.54.0",
    "ol": "10.7.0",
    "ol-mapbox-style": "12.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hotkeys-hook": "5.3.3",
    "react-i18next": "17.0.10",
    "react-router": "7.18.1",
    "shapefile.js": "1.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
