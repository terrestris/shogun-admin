    "@types/lodash": "4.17.24",
    "@types/node": "25.9.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-redux": "7.1.34",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "axe-html-reporter": "2.2.11",
    "babel-plugin-import": "1.13.8",
    "buffer": "6.0.3",
    "dotenv": "17.4.2",
