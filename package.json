{
  "name": "@terrestris/shogun-admin",
  "version": "18.1.1",
  "description": "The admin UI for the SHOGun Web-mapping backend.",
  "keywords": [
    "SHOGun",
    "WebMapping"
  ],
  "homepage": "https://github.com/terrestris/shogun-admin#readme",
  "bugs": {
    "url": "https://github.com/terrestris/shogun-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/terrestris/shogun-admin.git"
  },
  "license": "Apache-2.0 ",
  "author": "terrestris GmbH & Co. KG <info@terrestris.de>",
  "main": "index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rspack --config rspack.prod.js build",
    "build:analyze": "npm run build -- --analyze",
    "check": "npm run typecheck && npm run lint && npm run test",
    "clean:dist": "rimraf ./dist/* ./coverage/*",
    "lint": "npm run clean:dist && eslint -c eslint.config.mjs",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "semantic-release": "npm run clean:dist; npm run build; npx semantic-release",
    "start": "rspack serve --config rspack.dev.js",
    "test": "jest --coverage --maxWorkers=50%",
    "test:watch": "jest --watch",
    "e2e-tests": "npx playwright test",
    "smoke-tests": "npx playwright test e2e-tests/smoke.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "6.3.2",
    "@ant-design/pro-components": "2.8.10",
    "@ant-design/v5-patch-for-react-19": "1.0.3",
    "@casualbot/jest-sonar-reporter": "2.7.1",
    "@monaco-editor/react": "4.7.0",
    "@terrestris/base-util": "4.0.2",
    "@terrestris/ol-util": "21.3.2",
    "@terrestris/shogun-util": "10.12.0",
    "@uiw/react-md-editor": "4.1.1",
    "antd": "5.29.3",
    "i18next": "26.3.6",
